# .gitattributes — Git LFS configuration
# Run `git lfs install` once per machine before using this repo.
#
# Files tracked here are stored as LFS pointer files in git but the actual
# binary blobs live on the LFS server. They are downloaded automatically
# on `git clone`, `git pull`, or `pip install git+https://...` (requires
# git-lfs client installed on the machine doing the install).

# ── PyTorch checkpoint files ──────────────────────────────────────────────────
# Covers checkpoint_step_42952.pt and any future checkpoints added.
*.pt filter=lfs diff=lfs merge=lfs -text
# ── HuggingFace model weight files ───────────────────────────────────────────
# pytorch_model.bin inside distilbert-base-uncased/
*.bin filter=lfs diff=lfs merge=lfs -text
# ── Safetensors format (if model is ever re-saved in that format) ─────────────
*.safetensors filter=lfs diff=lfs merge=lfs -text
# ── Python source files — normal git, LF line endings ────────────────────────
*.py text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.json text eol=lf
*.csv text eol=lf
*.toml text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
