# .gitignore for con_noccai GitLab repo
#
# ── IMPORTANT: large binary files are tracked via Git LFS, NOT ignored.
# ── See .gitattributes for LFS patterns (*.pt, *.bin, *.safetensors).
# ── Do NOT add *.pt or *.bin here or they will be excluded from LFS too.

# ── Python clutter ────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/
*.egg

# ── Jupyter ───────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── Training outputs (all written to C:\Users\ryan.r.spencer\NOC_Model\) ──────
# These never belong in the repo — checkpoint saves, tensorboard logs, etc.
outputs/
logs/
runs/

# ── OneDrive temp files ───────────────────────────────────────────────────────
*.tmp
~$*
desktop.ini
Thumbs.db

# ── Conda/pip environments ───────────────────────────────────────────────────
.conda/
.env
*.env

# ── OS junk ──────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db

# ── IDE ───────────────────────────────────────────────────────────────────────
.vscode/settings.json
.idea/
*.suo
*.user

# ── Data files that should NOT be in git ─────────────────────────────────────
# Raw training data CSVs are large and contain potentially sensitive info.
# The bundled noc_2021_merged_clean.csv inside noc_inference/data/ is intentionally
# tracked (it's small and required for the package).
training data/
training_data/
raw_data/
251208_*.csv

# ── Revelio / evaluation datasets ────────────────────────────────────────────
revelio*.csv
Revelio*.csv
*_revelio_*.csv
*_labels.csv
