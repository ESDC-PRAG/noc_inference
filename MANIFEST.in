# MANIFEST.in
# Tells setuptools which non-.py files to include when building the package.
# Git LFS pointer files are replaced with real binaries during git clone/lfs pull.

# ── noc_inference data ────────────────────────────────────────────────────────
include noc_inference/data/noc_2021_merged_clean.csv

# ── Model checkpoint (stored in LFS, ~270 MB) ────────────────────────────────
include noc_inference/checkpoints/checkpoint_step_42952.pt

# ── DistilBERT-base-uncased base model ───────────────────────────────────────
# Small config/tokenizer files (normal git)
include noc_inference/models/distilbert-base-uncased/config.json
include noc_inference/models/distilbert-base-uncased/tokenizer_config.json
include noc_inference/models/distilbert-base-uncased/tokenizer.json
include noc_inference/models/distilbert-base-uncased/vocab.txt
# Large weight file (stored in LFS, ~265 MB)
include noc_inference/models/distilbert-base-uncased/pytorch_model.bin

# ── con_noccai_v7 supporting data ────────────────────────────────────────────
include con_noccai_v7/label_map.json

# ── Exclude clutter ──────────────────────────────────────────────────────────
global-exclude *.pyc
global-exclude __pycache__
global-exclude .DS_Store
global-exclude *.tmp
prune outputs
prune logs
prune .ipynb_checkpoints
